ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here
GROK_API_KEY=your_key_here
DEEPSEEK_API_KEY=your_key_here

WS_HOST=localhost
WS_PORT=8765
OVERLAY_HOST=localhost
OVERLAY_PORT=8766
ROUTER_MODEL=claude-haiku-4-5-20251001

QUEUE_MAX_SIZE=10
TRIGGER_COOLDOWN_SECONDS=3.0
DEDUP_WINDOW_SECONDS=5.0

# Provider timeouts per trigger class (seconds)
PROVIDER_TIMEOUT_FAST_SECONDS=5.0
PROVIDER_TIMEOUT_NORMAL_SECONDS=10.0
PROVIDER_TIMEOUT_EXTENDED_SECONDS=15.0

# Provider retries per trigger class
PROVIDER_RETRIES_FAST=0
PROVIDER_RETRIES_NORMAL=1

# Latency budgets (milliseconds)
LATENCY_BUDGET_FAST_MS=1500
LATENCY_BUDGET_NORMAL_MS=3000
LATENCY_BUDGET_EXTENDED_MS=5000

ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75

# Voice IDs - select from elevenlabs.io/voice-library and paste here
VOICE_CLAUVEN=
VOICE_GEPTIMA=
VOICE_GEMAUX=
VOICE_GROKTHAR=
VOICE_DEEPWILLA=

INTER_CHARACTER_GAP_SECONDS=0.5
LOG_LEVEL=INFO
TRANSCRIPT_PATH=logs/transcript.jsonl

# Vision (OBS screenshot loop)
VISION_ENABLED=false
VISION_INTERVAL_SECONDS=60.0
VISION_OBS_HOST=localhost
VISION_OBS_PORT=4455
VISION_OBS_PASSWORD=
VISION_MODEL=gpt-4o
VISION_MAX_TOKENS=150

# Vision flickbook
VISION_BURST_FRAMES=5
VISION_BURST_INTERVAL_SECONDS=2.0

# Vision log
VISION_LOG_ENABLED=true
VISION_LOG_MAX_CONTEXT_ENTRIES=5
VISION_LOG_MAX_FILE_ENTRIES=100

# Source name within the Gaming scene to capture. Must match OBS exactly.
# Set this to avoid capturing the Party overlay along with the game.
VISION_GAMEPLAY_SOURCE=Gameplay

# Twitch API (for game detection)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BROADCASTER_LOGIN=watchmoonie

# IGDB game lookup
IGDB_ENABLED=true

# STT (microphone listening)
STT_ENABLED=false
STT_MODEL=base
STT_DEVICE_INDEX=-1
STT_LANGUAGE=en
STT_COOLDOWN_SECONDS=90.0
STT_MIN_WORDS=5
STT_REACTION_MODEL=claude-haiku-4-5-20251001

# Session context
SESSION_CONTEXT_PATH=session/session_context.txt
